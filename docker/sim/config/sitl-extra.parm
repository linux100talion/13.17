# Дополнительные параметры SITL для GCE / слабого CPU.
# Загружается как второй --add-param-file поверх стандартного gazebo-iris.parm.

# Без этого "Main loop slow (249Hz < 400Hz)" → SITL считает FCU нестабильным.
SCHED_LOOP_RATE 100

# Отключить автодизарм при потере GCS (в симуляции GCS нет).
FS_GCS_ENABLE 0

# Убрать таймаут дизарма на земле.
DISARM_DELAY 0

# Отключить все pre-arm проверки (в симуляции IMU "несогласованы").
ARMING_CHECK 0
